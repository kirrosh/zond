{
  "name": "apitool",
  "version": "0.1.0",
  "description": "API testing platform — define tests in YAML, run from CLI or WebUI, generate from OpenAPI specs",
  "license": "MIT",
  "module": "index.ts",
  "type": "module",
  "keywords": [
    "api",
    "testing",
    "openapi",
    "yaml",
    "cli",
    "rest",
    "http"
  ],
  "bin": {
    "apitool": "src/cli/index.ts"
  },
  "scripts": {
    "apitool": "bun run src/cli/index.ts",
    "test": "bun test",
    "check": "tsc --noEmit",
    "build": "bun build --compile src/cli/index.ts --outfile apitool"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@readme/openapi-parser": "^5.5.0",
    "hono": "^4.12.2",
    "openapi-types": "^12.1.3",
    "zod": "^4.3.6"
  }
}
