{
  "name": "zond",
  "version": "0.15.0",
  "description": "AI-native API testing — OpenAPI → tests → execution → diagnostics",
  "author": {
    "name": "kirrosh",
    "url": "https://github.com/kirrosh"
  },
  "homepage": "https://github.com/kirrosh/zond",
  "repository": "https://github.com/kirrosh/zond",
  "license": "MIT",
  "keywords": [
    "api",
    "testing",
    "openapi",
    "yaml"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(*.yaml)",
        "hooks": [
          {
            "type": "command",
            "command": "zond validate \"$TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
