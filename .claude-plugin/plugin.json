{
  "name": "zond",
  "version": "0.14.0",
  "description": "AI-native API testing — OpenAPI → tests → execution → diagnostics",
  "author": {
    "name": "kirrosh",
    "url": "https://github.com/kirrosh"
  },
  "repository": "https://github.com/kirrosh/zond",
  "license": "MIT",
  "keywords": [
    "api",
    "testing",
    "openapi",
    "yaml",
    "mcp"
  ],
  "mcpServers": {
    "zond": {
      "command": "npx",
      "args": [
        "-y",
        "@kirrosh/zond@latest",
        "mcp"
      ]
    }
  },
  "skills": [
    "skills/api-testing",
    "skills/test-generation",
    "skills/test-diagnosis"
  ],
  "commands": [
    "commands/test-api.md",
    "commands/smoke.md",
    "commands/diagnose.md"
  ],
  "agents": [
    "agents/test-writer.md"
  ],
  "hooks": "hooks/hooks.json"
}
