{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "check": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "operation": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "operationId": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "method"
      ],
      "additionalProperties": false
    },
    "request_signature": {
      "type": "string"
    },
    "response_summary": {
      "type": "object",
      "properties": {
        "status": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "content_type": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ],
      "additionalProperties": false
    },
    "message": {
      "type": "string"
    },
    "evidence": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "recommended_action": {
      "type": "string",
      "enum": [
        "report_backend_bug",
        "fix_auth_config",
        "fix_test_logic",
        "fix_network_config",
        "fix_env",
        "fix_spec",
        "fix_fixture",
        "tighten_validation",
        "add_required_header",
        "wontfix_known_limitation"
      ]
    }
  },
  "required": [
    "check",
    "severity",
    "operation",
    "request_signature",
    "response_summary",
    "message"
  ],
  "additionalProperties": false
}
