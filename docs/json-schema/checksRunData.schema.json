{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "check": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "operation": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "method": {
                "type": "string"
              },
              "operationId": {
                "type": "string"
              }
            },
            "required": [
              "path",
              "method"
            ],
            "additionalProperties": false
          },
          "request_signature": {
            "type": "string"
          },
          "response_summary": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              "content_type": {
                "type": "string"
              }
            },
            "required": [
              "status"
            ],
            "additionalProperties": false
          },
          "message": {
            "type": "string"
          },
          "evidence": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "recommended_action": {
            "type": "string",
            "enum": [
              "report_backend_bug",
              "fix_auth_config",
              "fix_test_logic",
              "fix_network_config",
              "fix_env",
              "fix_spec",
              "fix_fixture",
              "tighten_validation",
              "add_required_header",
              "wontfix_known_limitation"
            ]
          }
        },
        "required": [
          "check",
          "severity",
          "operation",
          "request_signature",
          "response_summary",
          "message"
        ],
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "operations": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cases": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "checks_run": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "findings": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "by_severity": {
          "type": "object",
          "properties": {
            "low": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "medium": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "high": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "critical": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "additionalProperties": false
        },
        "skipped_outcomes": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        }
      },
      "required": [
        "operations",
        "cases",
        "checks_run",
        "findings",
        "by_severity",
        "skipped_outcomes"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "findings",
    "summary"
  ],
  "additionalProperties": false
}
