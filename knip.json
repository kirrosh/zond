{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/cli/index.ts",
    "scripts/**/*.ts",
    "tests/**/*.{ts,tsx}",
    "benchmarks/**/*.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/core/exporter/postman.ts",
    "src/cli/commands/init/templates/**",
    "src/db/queries/coverage.ts",
    "src/db/queries/settings.ts"
  ],
  "ignoreBinaries": ["tsc", "benchmarks/api/server.ts"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "exports": "warn",
    "types": "off"
  }
}
